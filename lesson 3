## 19. Main Python Implementation

### Student Performance Analyzer

```python
import numpy as np


PASSING_SCORE = 60.0


def validate_student_data(data: np.ndarray) -> None:
    """Validate the student dataset."""
    if data.ndim != 2:
        raise ValueError("Student data must be a two-dimensional array.")

    if data.shape[1] != 3:
        raise ValueError(
            "Each student must have exactly three features."
        )

    if data.shape[0] == 0:
        raise ValueError("Student data cannot be empty.")

    if np.isnan(data).any():
        raise ValueError("Student data cannot contain missing values.")

    if (data[:, 0] < 0).any():
        raise ValueError("Study hours cannot be negative.")

    if ((data[:, 1:] < 0) | (data[:, 1:] > 100)).any():
        raise ValueError(
            "Attendance and exam scores must be between 0 and 100."
        )


def calculate_feature_averages(
    data: np.ndarray,
) -> np.ndarray:
    """Calculate the average of each student feature."""
    return data.mean(axis=0)


def calculate_final_scores(data: np.ndarray) -> np.ndarray:
    """Calculate a weighted final score for each student."""
    study_hours = data[:, 0]
    attendance = data[:, 1]
    previous_scores = data[:, 2]

    normalized_hours = np.minimum(study_hours / 10.0 * 100.0, 100.0)

    return (
        normalized_hours * 0.20
        + attendance * 0.30
        + previous_scores * 0.50
    )


def classify_students(
    final_scores: np.ndarray,
) -> np.ndarray:
    """Classify students as passing or failing."""
    return np.where(
        final_scores >= PASSING_SCORE,
        "Pass",
        "Fail",
    )


def calculate_pass_rate(
    predictions: np.ndarray,
) -> float:
    """Calculate the percentage of passing students."""
    passed_count = np.sum(predictions == "Pass")
    return float(passed_count / predictions.size * 100.0)


def main() -> None:
    """Run the student performance analysis."""
    student_data = np.array(
        [
            [2.0, 60.0, 55.0],
            [4.0, 75.0, 70.0],
            [6.0, 90.0, 85.0],
            [3.0, 65.0, 60.0],
            [5.0, 80.0, 78.0],
        ],
        dtype=np.float64,
    )

    validate_student_data(student_data)

    feature_averages = calculate_feature_averages(student_data)
    final_scores = calculate_final_scores(student_data)
    predictions = classify_students(final_scores)
    pass_rate = calculate_pass_rate(predictions)

    print("Feature averages:")
    print(f"Study hours: {feature_averages[0]:.2f}")
    print(f"Attendance: {feature_averages[1]:.2f}")
    print(f"Previous score: {feature_averages[2]:.2f}")

    print("\nStudent results:")

    for index, (score, prediction) in enumerate(
        zip(final_scores, predictions),
        start=1,
    ):
        print(
            f"Student {index}: "
            f"{score:.2f} — {prediction}"
        )

    print(f"\nPass rate: {pass_rate:.2f}%")


if __name__ == "__main__":
    main()
```

