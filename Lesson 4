            "total_spent": [1000.0, 0.0],
        }
    )

    validate_customer_data(customers)

    cleaned = clean_customer_data(customers)

    assert cleaned.loc[0, "name"] == "Ali"
    assert cleaned.loc[0, "city"] == "Dubai"
    assert cleaned.loc[1, "city"] == "Unknown"

    enriched = add_customer_metrics(cleaned)

    assert enriched.loc[0, "average_order_value"] == 500.0
    assert enriched.loc[1, "average_order_value"] == 0.0
    assert not bool(
        enriched.loc[0, "high_value_customer"]
    )

    summary = create_city_summary(enriched)

    assert summary["customer_count"].sum() == 2
    assert summary["total_revenue"].sum() == 1000.0

    print("All tests passed.")


if __name__ == "__main__":
