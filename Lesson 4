# 24. Main Python Implementation

## Customer Purchase Analyzer

```python
from pathlib import Path

import pandas as pd


REQUIRED_COLUMNS = {
    "customer_id",
    "name",
    "city",
    "age",
    "purchases",
    "total_spent",
}


def validate_customer_data(data: pd.DataFrame) -> None:
    """Validate the structure and values of customer data."""
    if data.empty:
        raise ValueError("Customer dataset cannot be empty.")

    missing_columns = REQUIRED_COLUMNS - set(data.columns)

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )

    if data["customer_id"].isna().any():
        raise ValueError("Customer IDs cannot be missing.")

    if data["customer_id"].duplicated().any():
        raise ValueError("Customer IDs must be unique.")

    if (data["age"].dropna() < 0).any():
        raise ValueError("Customer age cannot be negative.")

    if (data["purchases"].dropna() < 0).any():
        raise ValueError("Purchase count cannot be negative.")

    if (data["total_spent"].dropna() < 0).any():
        raise ValueError("Total spending cannot be negative.")


def clean_customer_data(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Return a cleaned copy of customer data."""
    cleaned = data.copy()

    cleaned["name"] = cleaned["name"].str.strip()

    cleaned["city"] = (
        cleaned["city"]
        .str.strip()
        .str.title()
        .fillna("Unknown")
    )

    cleaned["age"] = cleaned["age"].fillna(
        cleaned["age"].median()
    )

    cleaned["purchases"] = cleaned["purchases"].fillna(0)

    cleaned["total_spent"] = cleaned["total_spent"].fillna(
        0.0
    )

    cleaned = cleaned.drop_duplicates(
        subset=["customer_id"]
    )

    return cleaned


def add_customer_metrics(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Add calculated customer metrics."""
    enriched = data.copy()

    enriched["average_order_value"] = (
        enriched["total_spent"]
        / enriched["purchases"].replace(0, pd.NA)
    )

    enriched["average_order_value"] = (
        enriched["average_order_value"].fillna(0.0)
    )

    enriched["high_value_customer"] = (
        enriched["total_spent"] >= 3000.0
    )

    return enriched


def create_city_summary(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Create aggregated customer statistics by city."""
    return (
        data.groupby(
            "city",
            as_index=False,
        )
        .agg(
            customer_count=("customer_id", "count"),
            total_purchases=("purchases", "sum"),
            total_revenue=("total_spent", "sum"),
            average_spending=("total_spent", "mean"),
        )
        .sort_values(
            by="total_revenue",
            ascending=False,
        )
        .reset_index(drop=True)
    )


def save_report(
    report: pd.DataFrame,
    output_path: Path,
) -> None:
    """Save the report as a CSV file."""
    output_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    report.to_csv(
        output_path,
        index=False,
    )


def main() -> None:
    """Run customer data analysis."""
    customers = pd.DataFrame(
        {
            "customer_id": [101, 102, 103, 104, 105],
            "name": [
                " Ali ",
                "Sara",
                "Ahmed",
                "Fatima",
                "Omar",
            ],
            "city": [
                "dubai",
                "Sharjah",
                "Dubai",
                None,
                "abu dhabi",
            ],
            "age": [25, 30, None, 35, 28],
            "purchases": [5, 8, 2, None, 10],
            "total_spent": [
                2500.0,
                4200.0,
                700.0,
                None,
                5100.0,
            ],
        }
    )

    validate_customer_data(customers)

    cleaned_customers = clean_customer_data(customers)
    enriched_customers = add_customer_metrics(
        cleaned_customers
    )

    city_summary = create_city_summary(
        enriched_customers
    )

    print("Cleaned customer data:")
    print(enriched_customers)

    print("\nCity summary:")
    print(city_summary)

    output_path = Path(
        "reports/customer_city_summary.csv"
    )

    save_report(
        city_summary,
        output_path,
    )

    print(f"\nReport saved to: {output_path}")


if __name__ == "__main__":
    main()
```

