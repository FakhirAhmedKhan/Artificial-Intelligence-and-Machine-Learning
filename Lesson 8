## 31. Main Project: Dataset File Pipeline

This program:

1. Loads a CSV dataset.
2. Validates required columns.
3. Converts numerical columns.
4. Removes invalid rows.
5. Generates a quality report.
6. Saves cleaned CSV and JSON metadata.

```python
import json
from pathlib import Path

import pandas as pd


REQUIRED_COLUMNS = {
    "student_id",
    "name",
    "study_hours",
    "attendance",
    "exam_score",
}


def validate_input_path(
    file_path: Path,
) -> None:
    """Validate an input CSV file path."""
    if not file_path.exists():
        raise FileNotFoundError(
            f"Dataset was not found: {file_path}"
        )

    if not file_path.is_file():
        raise ValueError(
            f"Expected a file: {file_path}"
        )

    if file_path.suffix.lower() != ".csv":
        raise ValueError(
            f"Expected a CSV file: {file_path}"
        )


def load_student_data(
    file_path: Path,
) -> pd.DataFrame:
    """Load student data from CSV."""
    validate_input_path(file_path)

    try:
        return pd.read_csv(file_path)
    except UnicodeDecodeError as error:
        raise ValueError(
            "The dataset is not valid UTF-8."
        ) from error
    except pd.errors.EmptyDataError as error:
        raise ValueError(
            "The CSV file is empty."
        ) from error
    except pd.errors.ParserError as error:
        raise ValueError(
            "The CSV structure is invalid."
        ) from error


def validate_columns(
    data: pd.DataFrame,
) -> None:
    """Validate required dataset columns."""
    missing_columns = (
        REQUIRED_COLUMNS - set(data.columns)
    )

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )


def clean_student_data(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Clean student records."""
    validate_columns(data)

    cleaned = data.copy()

    cleaned["name"] = (
        cleaned["name"]
        .replace(
            r"^\s*$",
            pd.NA,
            regex=True,
        )
        .str.strip()
        .str.title()
    )

    numerical_columns = [
        "study_hours",
        "attendance",
        "exam_score",
    ]

    for column in numerical_columns:
        cleaned[column] = pd.to_numeric(
            cleaned[column],
            errors="coerce",
        )

    cleaned = cleaned.dropna(
        subset=[
            "student_id",
            "name",
            "study_hours",
            "attendance",
            "exam_score",
        ]
    )

    valid_rows = (
        (cleaned["study_hours"] >= 0)
        & cleaned["attendance"].between(
            0,
            100,
        )
        & cleaned["exam_score"].between(
            0,
            100,
        )
    )

    cleaned = cleaned[valid_rows].copy()

    cleaned = cleaned.drop_duplicates(
        subset=["student_id"],
        keep="last",
    )

    cleaned = cleaned.reset_index(
        drop=True
    )

    return cleaned


def create_quality_metadata(
    raw_data: pd.DataFrame,
    cleaned_data: pd.DataFrame,
) -> dict[str, int | float]:
    """Create dataset-cleaning metadata."""
    raw_rows = len(raw_data)
    cleaned_rows = len(cleaned_data)
    removed_rows = raw_rows - cleaned_rows

    removal_percentage = (
        removed_rows / raw_rows * 100
        if raw_rows > 0
        else 0.0
    )

    return {
        "raw_rows": raw_rows,
        "cleaned_rows": cleaned_rows,
        "removed_rows": removed_rows,
        "removal_percentage": round(
            removal_percentage,
            2,
        ),
        "column_count": len(
            cleaned_data.columns
        ),
    }


def save_cleaned_data(
    data: pd.DataFrame,
    output_path: Path,
) -> None:
    """Save cleaned data as CSV."""
    output_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    data.to_csv(
        output_path,
        index=False,
    )


def save_metadata(
    metadata: dict[str, int | float],
    output_path: Path,
) -> None:
    """Save dataset metadata as JSON."""
    output_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    with output_path.open(
        mode="w",
        encoding="utf-8",
    ) as file:
        json.dump(
            metadata,
            file,
            indent=2,
        )


def run_pipeline(
    input_path: Path,
    cleaned_output_path: Path,
    metadata_output_path: Path,
) -> None:
    """Run the complete student-data pipeline."""
    raw_data = load_student_data(
        input_path
    )

    cleaned_data = clean_student_data(
        raw_data
    )

    metadata = create_quality_metadata(
        raw_data,
        cleaned_data,
    )

    save_cleaned_data(
        cleaned_data,
        cleaned_output_path,
    )

    save_metadata(
        metadata,
        metadata_output_path,
    )

    print(
        f"Raw rows: {metadata['raw_rows']}"
    )

    print(
        "Cleaned rows: "
        f"{metadata['cleaned_rows']}"
    )

    print(
        "Removed rows: "
        f"{metadata['removed_rows']}"
    )


def main() -> None:
    """Run the example pipeline."""
    input_path = Path(
        "data/raw/students.csv"
    )

    cleaned_output_path = Path(
        "data/processed/students_cleaned.csv"
    )

    metadata_output_path = Path(
        "reports/student_data_metadata.json"
    )

    run_pipeline(
        input_path,
        cleaned_output_path,
        metadata_output_path,
    )


if __name__ == "__main__":
    main()
```

