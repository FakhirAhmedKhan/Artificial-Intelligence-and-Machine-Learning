## 12. Python Implementation

### Student Dataset Analyzer

```python
from typing import NamedTuple


PASSING_SCORE = 60.0


class Student(NamedTuple):
    """Represent one student record."""

    name: str
    score: float


def validate_students(students: list[Student]) -> None:
    """Validate the student dataset."""
    if not students:
        raise ValueError("The student dataset cannot be empty.")

    for student in students:
        if not student.name.strip():
            raise ValueError("Student name cannot be empty.")

        if not 0 <= student.score <= 100:
            raise ValueError(
                f"Score for {student.name} must be between 0 and 100."
            )


def calculate_average(students: list[Student]) -> float:
    """Calculate the average student score."""
    total_score = sum(student.score for student in students)
    return total_score / len(students)


def assign_grade(score: float) -> str:
    """Convert a numerical score into a letter grade."""
    if score >= 90:
        return "A"

    if score >= 80:
        return "B"

    if score >= 70:
        return "C"

    if score >= 60:
        return "D"

    return "F"


def calculate_pass_rate(
    students: list[Student],
    passing_score: float = PASSING_SCORE,
) -> float:
    """Calculate the percentage of students who passed."""
    passed_count = sum(
        1
        for student in students
        if student.score >= passing_score
    )

    return passed_count / len(students) * 100


def build_grade_distribution(
    students: list[Student],
) -> dict[str, int]:
    """Count how many students received each grade."""
    distribution = {
        "A": 0,
        "B": 0,
        "C": 0,
        "D": 0,
        "F": 0,
    }

    for student in students:
        grade = assign_grade(student.score)
        distribution[grade] += 1

    return distribution


def find_top_student(students: list[Student]) -> Student:
    """Return the student with the highest score."""
    return max(students, key=lambda student: student.score)


def main() -> None:
    """Run the student dataset analysis."""
    students = [
        Student("Ali", 92.0),
        Student("Sara", 85.0),
        Student("Ahmed", 58.0),
        Student("Fatima", 76.0),
        Student("Omar", 64.0),
    ]

    validate_students(students)

    average_score = calculate_average(students)
    pass_rate = calculate_pass_rate(students)
    grade_distribution = build_grade_distribution(students)
    top_student = find_top_student(students)

    print(f"Average score: {average_score:.2f}")
    print(f"Pass rate: {pass_rate:.2f}%")
    print(
        f"Top student: {top_student.name} "
        f"({top_student.score:.2f})"
    )

    print("\nGrade distribution:")

    for grade, count in grade_distribution.items():
        print(f"{grade}: {count}")


if __name__ == "__main__":
    main()
```

### Expected Output

```text
Average score: 75.00
Pass rate: 80.00%
Top student: Ali (92.00)

Grade distribution:
A: 1
B: 1
C: 1
D: 1
F: 1
```

