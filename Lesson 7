## 25. Data Validation Function

Cleaning and validation are different.

Cleaning changes data.

Validation checks whether the cleaned result meets requirements.

```python
REQUIRED_COLUMNS = {
    "customer_id",
    "name",
    "city",
    "age",
    "total_spent",
}


def validate_cleaned_customer_data(
    data: pd.DataFrame,
) -> None:
    """Validate cleaned customer data."""
    if data.empty:
        raise ValueError(
            "Customer dataset cannot be empty."
        )

    missing_columns = (
        REQUIRED_COLUMNS - set(data.columns)
    )

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )

    if data["customer_id"].isna().any():
        raise ValueError(
            "Customer IDs cannot be missing."
        )

    if data["customer_id"].duplicated().any():
        raise ValueError(
            "Customer IDs must be unique."
        )

    if data["name"].isna().any():
        raise ValueError(
            "Customer names cannot be missing."
        )

    if (
        (data["age"] < MINIMUM_AGE)
        | (data["age"] > MAXIMUM_AGE)
    ).any():
        raise ValueError(
            "Customer age is outside the valid range."
        )

    if (data["total_spent"] < 0).any():
        raise ValueError(
            "Total spending cannot be negative."
        )
```

