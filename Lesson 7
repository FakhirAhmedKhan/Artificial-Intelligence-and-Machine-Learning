## 26. Main Python Implementation

```python
from pathlib import Path
from typing import Final

import pandas as pd


MINIMUM_AGE: Final[int] = 0
MAXIMUM_AGE: Final[int] = 120

REQUIRED_COLUMNS = {
    "customer_id",
    "name",
    "city",
    "age",
    "total_spent",
}


def create_dirty_customer_data() -> pd.DataFrame:
    """Create a sample dirty customer dataset."""
    return pd.DataFrame(
        {
            "customer_id": [
                101,
                102,
                102,
                103,
                104,
                105,
                106,
            ],
            "name": [
                " Ali ",
                "sara",
                "sara",
                "AHMED",
                "Fatima",
                "",
                "Noor",
            ],
            "city": [
                "Dubai",
                "dubai",
                "dubai",
                "Sharjah ",
                "abu dhabi",
                None,
                "DUBAI",
            ],
            "age": [
                25,
                None,
                None,
                -5,
                31,
                250,
                "29",
            ],
            "total_spent": [
                2500,
                3200,
                3200,
                1800,
                "unknown",
                4000,
                2100,
            ],
        }
    )


def generate_quality_report(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Generate a column-level data-quality report."""
    report = pd.DataFrame(
        {
            "column": data.columns,
            "data_type": [
                str(data[column].dtype)
                for column in data.columns
            ],
            "missing_count": [
                int(data[column].isna().sum())
                for column in data.columns
            ],
            "missing_percentage": [
                float(
                    data[column].isna().mean()
                    * 100
                )
                for column in data.columns
            ],
            "unique_values": [
                int(data[column].nunique(
                    dropna=True
                ))
                for column in data.columns
            ],
        }
    )

    return report


def clean_customer_data(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Clean customer data without modifying the input."""
    cleaned = data.copy()

    cleaned = cleaned.drop_duplicates()

    text_columns = [
        "name",
        "city",
    ]

    for column in text_columns:
        cleaned[column] = (
            cleaned[column]
            .replace(
                r"^\s*$",
                pd.NA,
                regex=True,
            )
            .str.strip()
            .str.title()
        )

    numeric_columns = [
        "age",
        "total_spent",
    ]

    for column in numeric_columns:
        cleaned[column] = pd.to_numeric(
            cleaned[column],
            errors="coerce",
        )

    invalid_age_mask = (
        (cleaned["age"] < MINIMUM_AGE)
        | (cleaned["age"] > MAXIMUM_AGE)
    )

    cleaned.loc[
        invalid_age_mask,
        "age",
    ] = pd.NA

    cleaned["age"] = cleaned["age"].fillna(
        cleaned["age"].median()
    )

    cleaned["total_spent"] = (
        cleaned["total_spent"].fillna(
            cleaned["total_spent"].median()
        )
    )

    cleaned["city"] = cleaned["city"].fillna(
        "Unknown"
    )

    cleaned = cleaned.dropna(
        subset=[
            "customer_id",
            "name",
        ]
    )

    cleaned = cleaned.drop_duplicates(
        subset=["customer_id"],
        keep="last",
    )

    cleaned = cleaned.reset_index(
        drop=True
    )

    return cleaned


def validate_cleaned_customer_data(
    data: pd.DataFrame,
) -> None:
    """Validate the cleaned customer dataset."""
    if data.empty:
        raise ValueError(
            "Customer dataset cannot be empty."
        )

    missing_columns = (
        REQUIRED_COLUMNS - set(data.columns)
    )

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )

    if data["customer_id"].isna().any():
        raise ValueError(
            "Customer IDs cannot be missing."
        )

    if data["customer_id"].duplicated().any():
        raise ValueError(
            "Customer IDs must be unique."
        )

    if data["name"].isna().any():
        raise ValueError(
            "Customer names cannot be missing."
        )

    if (
        (data["age"] < MINIMUM_AGE)
        | (data["age"] > MAXIMUM_AGE)
    ).any():
        raise ValueError(
            "Customer ages are invalid."
        )

    if (data["total_spent"] < 0).any():
        raise ValueError(
            "Total spending cannot be negative."
        )


def save_cleaned_data(
    data: pd.DataFrame,
    output_path: Path,
) -> None:
    """Save cleaned data to a CSV file."""
    output_path.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    data.to_csv(
        output_path,
        index=False,
    )


def main() -> None:
    """Run the customer-data cleaning pipeline."""
    dirty_data = create_dirty_customer_data()

    print("Original data:")
    print(dirty_data)

    print("\nOriginal quality report:")
    print(
        generate_quality_report(
            dirty_data
        )
    )

    cleaned_data = clean_customer_data(
        dirty_data
    )

    validate_cleaned_customer_data(
        cleaned_data
    )

    print("\nCleaned data:")
    print(cleaned_data)

    print("\nCleaned quality report:")
    print(
        generate_quality_report(
            cleaned_data
        )
    )

    output_path = Path(
        "reports/cleaned_customers.csv"
    )

    save_cleaned_data(
        cleaned_data,
        output_path,
    )

    print(
        "\nCleaned dataset saved to: "
        f"{output_path}"
    )


if __name__ == "__main__":
    main()
