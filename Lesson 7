## 24. A Reusable Cleaning Pipeline

```python
from typing import Final

import pandas as pd


MINIMUM_AGE: Final[int] = 0
MAXIMUM_AGE: Final[int] = 120


def clean_customer_data(
    data: pd.DataFrame,
) -> pd.DataFrame:
    """Clean and return customer data."""
    cleaned = data.copy()

    cleaned = cleaned.drop_duplicates()

    cleaned["name"] = (
        cleaned["name"]
        .replace(r"^\s*$", pd.NA, regex=True)
        .str.strip()
        .str.title()
    )

    cleaned["city"] = (
        cleaned["city"]
        .replace(r"^\s*$", pd.NA, regex=True)
        .str.strip()
        .str.title()
    )

    cleaned["age"] = pd.to_numeric(
        cleaned["age"],
        errors="coerce",
    )

    cleaned["total_spent"] = pd.to_numeric(
        cleaned["total_spent"],
        errors="coerce",
    )

    invalid_age_mask = (
        (cleaned["age"] < MINIMUM_AGE)
        | (cleaned["age"] > MAXIMUM_AGE)
    )

    cleaned.loc[
        invalid_age_mask,
        "age",
    ] = pd.NA

    cleaned["age"] = cleaned["age"].fillna(
        cleaned["age"].median()
    )

    cleaned["total_spent"] = (
        cleaned["total_spent"].fillna(
            cleaned["total_spent"].median()
        )
    )

    cleaned["city"] = cleaned["city"].fillna(
        "Unknown"
    )

    cleaned = cleaned.dropna(
        subset=[
            "customer_id",
            "name",
        ]
    )

    cleaned = cleaned.drop_duplicates(
        subset=["customer_id"],
        keep="last",
    )

    cleaned = cleaned.reset_index(
        drop=True
    )

    return cleaned
```

