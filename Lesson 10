### `src/ml_utils/statistics.py`

```python
from collections.abc import Sequence

from ml_utils.validation import validate_numeric_values


def calculate_mean(
    values: Sequence[float],
) -> float:
    """Calculate the arithmetic mean."""
    validate_numeric_values(values)

    return float(sum(values) / len(values))


def calculate_range(
    values: Sequence[float],
) -> float:
    """Calculate the difference between maximum and minimum."""
    validate_numeric_values(values)

    return float(max(values) - min(values))
```

Mean formula:

[
\bar{x} = \frac{\sum x_i}{n}
]

Range formula:

[
R = x_{\max} - x_{\min}
]

---

### `src/ml_utils/__init__.py`

```python
from ml_utils.statistics import calculate_mean, calculate_range

__all__ = [
    "calculate_mean",
    "calculate_range",
]
```

This exposes a cleaner package interface:

```python
from ml_utils import calculate_mean
```

instead of:

```python
from ml_utils.statistics import calculate_mean
```

