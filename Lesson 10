### `src/main.py`

```python
from ml_utils import calculate_mean, calculate_range


def main() -> None:
    """Run the statistics example."""
    scores = [72.0, 85.0, 91.0, 64.0, 88.0]

    mean_score = calculate_mean(scores)
    score_range = calculate_range(scores)

    print(f"Mean score: {mean_score:.2f}")
    print(f"Score range: {score_range:.2f}")


if __name__ == "__main__":
    main()
```

