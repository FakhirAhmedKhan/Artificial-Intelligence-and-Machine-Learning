## 25. Reusable API Client

```python
from typing import Any

import requests


class ApiClient:
    """Provide reusable JSON API operations."""

    def __init__(
        self,
        base_url: str,
        api_key: str | None = None,
        timeout: float = 10.0,
    ) -> None:
        """Initialize the API client."""
        self.base_url = base_url.rstrip("/")
        self.timeout = timeout
        self.session = requests.Session()

        self.session.headers.update(
            {
                "Accept": "application/json",
                "User-Agent": "MLDataClient/1.0",
            }
        )

        if api_key:
            self.session.headers.update(
                {
                    "Authorization": (
                        f"Bearer {api_key}"
                    )
                }
            )

    def get(
        self,
        endpoint: str,
        params: dict[str, Any] | None = None,
    ) -> Any:
        """Send a GET request and return JSON."""
        url = self._build_url(endpoint)

        try:
            response = self.session.get(
                url,
                params=params,
                timeout=self.timeout,
            )

            response.raise_for_status()

            return response.json()

        except requests.Timeout as error:
            raise RuntimeError(
                f"Request timed out: {url}"
            ) from error

        except requests.ConnectionError as error:
            raise RuntimeError(
                f"Could not connect to API: {url}"
            ) from error

        except requests.HTTPError as error:
            raise RuntimeError(
                "API returned an HTTP error: "
                f"{error}"
            ) from error

        except requests.JSONDecodeError as error:
            raise RuntimeError(
                "API returned invalid JSON."
            ) from error

    def post(
        self,
        endpoint: str,
        payload: dict[str, Any],
    ) -> Any:
        """Send a JSON POST request."""
        url = self._build_url(endpoint)

        try:
            response = self.session.post(
                url,
                json=payload,
                timeout=self.timeout,
            )

            response.raise_for_status()

            return response.json()

        except requests.RequestException as error:
            raise RuntimeError(
                f"API request failed: {url}"
            ) from error

    def close(self) -> None:
        """Close the underlying HTTP session."""
        self.session.close()

    def _build_url(
        self,
        endpoint: str,
    ) -> str:
        """Build a complete API URL."""
        normalized_endpoint = endpoint.lstrip("/")

        return (
            f"{self.base_url}/"
            f"{normalized_endpoint}"
        )
```

