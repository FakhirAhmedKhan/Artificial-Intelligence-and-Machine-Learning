## 30. Unit Testing Without Real API Calls

Unit tests should not depend on a live API.

Reasons:

* Network may be unavailable
* API may be slow
* Data may change
* Rate limits may be triggered
* Tests become unreliable

Use mocks.

```python
from unittest.mock import Mock, patch


def run_tests() -> None:
    client = ApiClient(
        base_url="https://api.example.com/v1"
    )

    mock_response = Mock()
    mock_response.raise_for_status.return_value = None
    mock_response.json.return_value = {
        "id": 1,
        "name": "Ali",
        "score": 85,
    }

    with patch.object(
        client.session,
        "get",
        return_value=mock_response,
    ) as mocked_get:
        result = client.get(
            "/students/1"
        )

    assert result["id"] == 1
    assert result["name"] == "Ali"
    assert result["score"] == 85

    mocked_get.assert_called_once()

    called_url = mocked_get.call_args.args[0]

    assert called_url == (
        "https://api.example.com/v1/students/1"
    )

    client.close()

    print("All tests passed.")


if __name__ == "__main__":
    run_tests()
```

