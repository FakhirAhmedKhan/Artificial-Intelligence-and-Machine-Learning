## 27. Using the Client

```python
import os


def main() -> None:
    """Use the API client."""
    api_key = os.getenv("API_KEY")

    client = ApiClient(
        base_url="https://api.example.com/v1",
        api_key=api_key,
        timeout=10,
    )

    try:
        students = client.get(
            "/students",
            params={
                "course": "AI",
                "limit": 100,
            },
        )

        print(students)

        prediction = client.post(
            "/predictions",
            payload={
                "study_hours": 6.0,
                "attendance": 90,
                "previous_score": 82,
            },
        )

        print(prediction)

    finally:
        client.close()


if __name__ == "__main__":
    main()
```

`finally` ensures the client is closed whether the requests succeed or fail.

