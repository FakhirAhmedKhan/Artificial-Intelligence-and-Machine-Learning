## 28. Main Python Implementation

## Exploratory Student Analysis Report

```python
from pathlib import Path

import matplotlib.pyplot as plt
import pandas as pd
import seaborn as sns


REQUIRED_COLUMNS = {
    "student",
    "study_hours",
    "attendance",
    "exam_score",
    "gender",
    "course",
}


def validate_student_data(
    data: pd.DataFrame,
) -> None:
    """Validate the student-analysis dataset."""
    if data.empty:
        raise ValueError(
            "Student dataset cannot be empty."
        )

    missing_columns = (
        REQUIRED_COLUMNS - set(data.columns)
    )

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )

    numerical_columns = [
        "study_hours",
        "attendance",
        "exam_score",
    ]

    if data[numerical_columns].isna().any().any():
        raise ValueError(
            "Numerical columns cannot contain missing values."
        )

    if (data["study_hours"] < 0).any():
        raise ValueError(
            "Study hours cannot be negative."
        )

    percentage_columns = [
        "attendance",
        "exam_score",
    ]

    for column in percentage_columns:
        invalid_values = (
            (data[column] < 0)
            | (data[column] > 100)
        )

        if invalid_values.any():
            raise ValueError(
                f"{column} must be between 0 and 100."
            )


def save_score_distribution(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save an exam-score distribution."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    sns.histplot(
        data=data,
        x="exam_score",
        bins=6,
        kde=True,
        ax=axis,
    )

    axis.set_title(
        "Exam Score Distribution"
    )

    axis.set_xlabel("Exam Score")
    axis.set_ylabel("Student Count")

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "score_distribution.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def save_study_score_relationship(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save a study-score scatter plot."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    sns.scatterplot(
        data=data,
        x="study_hours",
        y="exam_score",
        hue="course",
        style="gender",
        ax=axis,
    )

    axis.set_title(
        "Study Hours vs Exam Score"
    )

    axis.set_xlabel("Study Hours")
    axis.set_ylabel("Exam Score")

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "study_hours_vs_score.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def save_course_boxplot(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save course score distributions."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    sns.boxplot(
        data=data,
        x="course",
        y="exam_score",
        ax=axis,
    )

    sns.stripplot(
        data=data,
        x="course",
        y="exam_score",
        ax=axis,
    )

    axis.set_title(
        "Exam Scores by Course"
    )

    axis.set_xlabel("Course")
    axis.set_ylabel("Exam Score")

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "course_score_distribution.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def save_course_countplot(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save student counts by course."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    sns.countplot(
        data=data,
        x="course",
        ax=axis,
    )

    axis.set_title(
        "Students by Course"
    )

    axis.set_xlabel("Course")
    axis.set_ylabel("Student Count")

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "students_by_course.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def save_correlation_heatmap(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save a feature correlation heatmap."""
    numerical_data = data[
        [
            "study_hours",
            "attendance",
            "exam_score",
        ]
    ]

    correlation_matrix = numerical_data.corr()

    figure, axis = plt.subplots(
        figsize=(7, 5)
    )

    sns.heatmap(
        correlation_matrix,
        annot=True,
        fmt=".2f",
        ax=axis,
    )

    axis.set_title(
        "Student Feature Correlations"
    )

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "correlation_heatmap.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def generate_visual_report(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Generate all exploratory-analysis charts."""
    output_directory.mkdir(
        parents=True,
        exist_ok=True,
    )

    sns.set_theme(style="whitegrid")

    save_score_distribution(
        data,
        output_directory,
    )

    save_study_score_relationship(
        data,
        output_directory,
    )

    save_course_boxplot(
        data,
        output_directory,
    )

    save_course_countplot(
        data,
        output_directory,
    )

    save_correlation_heatmap(
        data,
        output_directory,
    )


