## 28. Main Python Implementation

### Student Performance Visualization Report

```python
from pathlib import Path

import matplotlib.pyplot as plt
import pandas as pd


REQUIRED_COLUMNS = {
    "student",
    "study_hours",
    "attendance",
    "exam_score",
}


def validate_student_data(
    data: pd.DataFrame,
) -> None:
    """Validate student performance data."""
    if data.empty:
        raise ValueError(
            "Student dataset cannot be empty."
        )

    missing_columns = (
        REQUIRED_COLUMNS - set(data.columns)
    )

    if missing_columns:
        raise ValueError(
            "Missing required columns: "
            f"{sorted(missing_columns)}"
        )

    numerical_columns = [
        "study_hours",
        "attendance",
        "exam_score",
    ]

    if data[numerical_columns].isna().any().any():
        raise ValueError(
            "Numerical columns cannot contain missing values."
        )

    if (data["study_hours"] < 0).any():
        raise ValueError(
            "Study hours cannot be negative."
        )

    if (
        (data["attendance"] < 0)
        | (data["attendance"] > 100)
    ).any():
        raise ValueError(
            "Attendance must be between 0 and 100."
        )

    if (
        (data["exam_score"] < 0)
        | (data["exam_score"] > 100)
    ).any():
        raise ValueError(
            "Exam score must be between 0 and 100."
        )


def create_score_distribution(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save the score-distribution histogram."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    axis.hist(
        data["exam_score"],
        bins=5,
        edgecolor="black",
    )

    axis.set_title(
        "Distribution of Exam Scores"
    )

    axis.set_xlabel("Exam Score")
    axis.set_ylabel("Number of Students")
    axis.grid(axis="y")

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "score_distribution.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def create_study_score_scatter(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save the study-hours scatter plot."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    axis.scatter(
        data["study_hours"],
        data["exam_score"],
    )

    axis.set_title(
        "Study Hours vs Exam Score"
    )

    axis.set_xlabel("Study Hours")
    axis.set_ylabel("Exam Score")
    axis.grid(True)

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "study_hours_vs_score.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def create_student_score_bar_chart(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create and save scores for each student."""
    sorted_data = data.sort_values(
        by="exam_score",
        ascending=False,
    )

    figure, axis = plt.subplots(
        figsize=(9, 5)
    )

    axis.bar(
        sorted_data["student"],
        sorted_data["exam_score"],
    )

    axis.set_title(
        "Exam Scores by Student"
    )

    axis.set_xlabel("Student")
    axis.set_ylabel("Exam Score")
    axis.set_ylim(0, 100)

    axis.tick_params(
        axis="x",
        rotation=45,
    )

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "student_scores.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def create_attendance_score_scatter(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create attendance and score relationship chart."""
    figure, axis = plt.subplots(
        figsize=(8, 5)
    )

    axis.scatter(
        data["attendance"],
        data["exam_score"],
    )

    axis.set_title(
        "Attendance vs Exam Score"
    )

    axis.set_xlabel("Attendance Percentage")
    axis.set_ylabel("Exam Score")
    axis.set_xlim(0, 100)
    axis.set_ylim(0, 100)
    axis.grid(True)

    figure.tight_layout()

    figure.savefig(
        output_directory
        / "attendance_vs_score.png",
        dpi=300,
        bbox_inches="tight",
    )

    plt.close(figure)


def create_all_charts(
    data: pd.DataFrame,
    output_directory: Path,
) -> None:
    """Create all student-performance charts."""
    output_directory.mkdir(
        parents=True,
        exist_ok=True,
    )

    create_score_distribution(
        data,
        output_directory,
    )

    create_study_score_scatter(
        data,
        output_directory,
    )

    create_student_score_bar_chart(
        data,
        output_directory,
    )

    create_attendance_score_scatter(
        data,
        output_directory,
    )


def main() -> None:
    """Generate student-performance visualizations."""
    student_data = pd.DataFrame(
        {
            "student": [
                "Ali",
                "Sara",
                "Ahmed",
                "Fatima",
                "Omar",
                "Ayesha",
                "Hassan",
                "Mariam",
            ],
            "study_hours": [
                2.0,
                5.0,
                3.0,
                7.0,
                1.5,
                6.0,
                4.0,
                8.0,
            ],
            "attendance": [
                60,
                82,
                70,
                95,
                55,
                88,
                76,
                98,
            ],
            "exam_score": [
                52,
                78,
                65,
                94,
                45,
                86,
                72,
                97,
            ],
        }
    )

    validate_student_data(student_data)

    output_directory = Path(
        "reports/student_charts"
    )

    create_all_charts(
        student_data,
        output_directory,
    )

    print(
        "Charts saved to: "
        f"{output_directory}"
    )


if __name__ == "__main__":
    main()
```

