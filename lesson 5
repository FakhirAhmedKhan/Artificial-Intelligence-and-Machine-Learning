## 32. Unit Tests

Visual output cannot be fully tested using simple equality checks, but we can test validation, file creation, and function execution.

```python
from pathlib import Path
from tempfile import TemporaryDirectory

import pandas as pd


def run_tests() -> None:
    valid_data = pd.DataFrame(
        {
            "student": ["Ali", "Sara"],
            "study_hours": [2.0, 5.0],
            "attendance": [60.0, 85.0],
            "exam_score": [55.0, 82.0],
        }
    )

    validate_student_data(valid_data)

    with TemporaryDirectory() as directory:
        output_directory = Path(directory)

        create_all_charts(
            valid_data,
            output_directory,
        )

        expected_files = [
            "score_distribution.png",
            "study_hours_vs_score.png",
            "student_scores.png",
            "attendance_vs_score.png",
        ]

        for filename in expected_files:
            file_path = (
                output_directory / filename
            )

            assert file_path.exists()
            assert file_path.stat().st_size > 0

    invalid_data = valid_data.copy()
    invalid_data.loc[0, "exam_score"] = 110

    try:
        validate_student_data(invalid_data)
        raise AssertionError(
            "Expected ValueError was not raised."
        )
    except ValueError:
        pass

    print("All tests passed.")


if __name__ == "__main__":
    run_tests()
```

